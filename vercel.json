{
  "version": 2,
  "builds": [
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "web/index.html" },
    { "src": "/test", "dest": "web/test.html" },
    { "src": "/test.html", "dest": "web/test.html" },
    { "src": "/capture", "dest": "web/capture.html" },
    { "src": "/capture.html", "dest": "web/capture.html" },
    { "src": "/config.js", "dest": "web/config.js" },
    { "src": "/models/(.*)", "dest": "web/models/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    }
  ]
}
